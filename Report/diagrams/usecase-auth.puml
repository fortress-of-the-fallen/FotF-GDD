@startuml
left to right direction

skinparam backgroundColor #0b1220
skinparam shadowing false
skinparam defaultFontName DejaVu Sans
skinparam defaultFontColor #e5e7eb
skinparam ArrowColor #cbd5e1
skinparam packageStyle rectangle
skinparam rectangle {
  BorderColor #64748b
  FontColor #e2e8f0
}
skinparam actor {
  BorderColor #93c5fd
  FontColor #dbeafe
}
skinparam usecase {
  BorderColor #f8fafc
  FontColor #f8fafc
  BackgroundColor #1f2937
}

actor Player as player
rectangle "Auth Module" #102a43 {
  usecase "Register" as UC_Register #1f3b57
  usecase "Login" as UC_Login #1f3b57
  usecase "Refresh Token" as UC_Refresh #1f3b57
  usecase "Logout" as UC_Logout #1f3b57
}
rectangle "Security" #3a2e12 {
  usecase "JWT Guard + Roles" as UC_Guard #5a4718
}
rectangle "Persistence" #3f1d2e {
  usecase "accounts/User" as DB_User #5b233f
  usecase "refresh_tokens/Session" as DB_Session #5b233f
  usecase "players/Player" as DB_Player #5b233f
}
player --> UC_Register
player --> UC_Login
player --> UC_Refresh
player --> UC_Logout
UC_Logout --> UC_Guard : include
UC_Register --> DB_User
UC_Login --> DB_User
UC_Login --> DB_Session
UC_Login --> DB_Player
UC_Refresh --> DB_Session
UC_Logout --> DB_Session
@enduml
