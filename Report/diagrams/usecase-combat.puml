@startuml
left to right direction

skinparam backgroundColor #0b1220
skinparam shadowing false
skinparam defaultFontName DejaVu Sans
skinparam defaultFontColor #e5e7eb
skinparam ArrowColor #cbd5e1
skinparam packageStyle rectangle
skinparam rectangle {
  BorderColor #64748b
  FontColor #e2e8f0
}
skinparam actor {
  BorderColor #93c5fd
  FontColor #dbeafe
}
skinparam usecase {
  BorderColor #f8fafc
  FontColor #f8fafc
  BackgroundColor #1f2937
}

actor Player as player
rectangle "Combat Module" #3a0f1a {
  usecase "Start Battle" as UC_Start #5f1328
  usecase "Finish Battle" as UC_Finish #5f1328
}
rectangle "Persistence" #3f1d2e {
  usecase "battle_sessions" as DB_B #5b233f
  usecase "reward_transactions" as DB_RT #5b233f
  usecase "leaderboard_scores" as DB_LS #5b233f
  usecase "players" as DB_P #5b233f
}
player --> UC_Start
player --> UC_Finish
UC_Start --> DB_B
UC_Finish --> DB_B
UC_Finish --> DB_RT
UC_Finish --> DB_LS
UC_Finish --> DB_P
@enduml
