flowchart LR
  classDef actor fill:#0b1f3a,stroke:#60a5fa,stroke-width:2px,color:#e6f0ff;
  classDef endpoint fill:#3a0f1a,stroke:#fb7185,stroke-width:1px,color:#fff1f2;
  classDef service fill:#1f2937,stroke:#f43f5e,stroke-width:1px,color:#fff5f7;
  classDef db fill:#3f1d2e,stroke:#f9a8d4,stroke-width:1px,color:#fff1f7;

  A([Player])

  subgraph API[Battle API]
    direction TB
    B1[POST /v1/battles/start]
    B2[POST /v1/battles/:battleId/finish]
  end

  subgraph APP[Domain Services]
    BS[BattleService]
    RS[RewardService]
  end

  subgraph DATA[Persistence]
    B[(battle_sessions)]
    RT[(reward_transactions)]
    LS[(leaderboard_scores)]
    P[(players)]
  end

  A --> B1 --> BS
  A --> B2 --> BS
  BS --> B
  BS --> RS --> RT
  BS --> LS
  BS --> P

  class A actor;
  class B1,B2 endpoint;
  class BS,RS service;
  class B,RT,LS,P db;
