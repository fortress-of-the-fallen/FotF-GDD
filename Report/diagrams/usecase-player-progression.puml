@startuml
left to right direction

skinparam backgroundColor #0b1220
skinparam shadowing false
skinparam defaultFontName DejaVu Sans
skinparam defaultFontColor #e5e7eb
skinparam ArrowColor #cbd5e1
skinparam packageStyle rectangle
skinparam rectangle {
  BorderColor #64748b
  FontColor #e2e8f0
}
skinparam actor {
  BorderColor #93c5fd
  FontColor #dbeafe
}
skinparam usecase {
  BorderColor #f8fafc
  FontColor #f8fafc
  BackgroundColor #1f2937
}

actor Player as player
rectangle "Progression Module" #12324b {
  usecase "Get Player State" as UC_GetPlayer #1c4a6e
  usecase "Update Profile" as UC_UpdateProfile #1c4a6e
  usecase "Update Tutorial Progress" as UC_Tutorial #1c4a6e
  usecase "View Quests" as UC_ViewQuests #1c4a6e
  usecase "Claim Quest Reward" as UC_ClaimQuest #1c4a6e
  usecase "Claim Track Reward" as UC_ClaimTrack #1c4a6e
  usecase "View Leaderboard" as UC_Leaderboard #1c4a6e
  usecase "View My Rank" as UC_MyRank #1c4a6e
}
rectangle "Persistence" #3f1d2e {
  usecase "players" as DB_P #5b233f
  usecase "player_quests" as DB_PQ #5b233f
  usecase "player_quest_progress_rewards" as DB_PQR #5b233f
  usecase "leaderboard_scores" as DB_LBS #5b233f
}
player --> UC_GetPlayer
player --> UC_UpdateProfile
player --> UC_Tutorial
player --> UC_ViewQuests
player --> UC_ClaimQuest
player --> UC_ClaimTrack
player --> UC_Leaderboard
player --> UC_MyRank
UC_GetPlayer --> DB_P
UC_UpdateProfile --> DB_P
UC_Tutorial --> DB_P
UC_ViewQuests --> DB_PQ
UC_ClaimQuest --> DB_PQ
UC_ClaimTrack --> DB_PQR
UC_ClaimQuest --> DB_P
UC_ClaimTrack --> DB_P
UC_Leaderboard --> DB_LBS
UC_MyRank --> DB_LBS
@enduml
