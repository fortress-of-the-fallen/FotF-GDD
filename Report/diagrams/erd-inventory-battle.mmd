    BATTLE_SESSION {
        string id PK
        string playerId FK
        string opponentPlayerId
        string mode
        int seed
        string status
        datetime startedAt
        datetime expiresAt
        datetime finishedAt
        string result
        json summary
        json rewards
        string configVersion
    }

    REWARD_TRANSACTION {
        string id PK
        string playerId FK
        string sourceType
        string sourceId
        string idempotencyKey
        json changes
        json balanceAfter
        datetime createdAt
    }

    PLAYER ||--o{ PLAYER_INVENTORY_ITEM : owns
