@startuml
left to right direction

skinparam backgroundColor #0b1220
skinparam shadowing false
skinparam defaultFontName DejaVu Sans
skinparam defaultFontColor #e5e7eb
skinparam ArrowColor #cbd5e1
skinparam packageStyle rectangle
skinparam rectangle {
  BorderColor #64748b
  FontColor #e2e8f0
}
skinparam actor {
  BorderColor #93c5fd
  FontColor #dbeafe
}
skinparam usecase {
  BorderColor #f8fafc
  FontColor #f8fafc
  BackgroundColor #1f2937
}

actor Player as player
rectangle "Inventory / Gacha Module" #4a2b0f {
  usecase "Get Inventory" as UC_GetInv #7a4312
  usecase "Upgrade Hero" as UC_UpgradeHero #7a4312
  usecase "Evolve Hero" as UC_EvolveHero #7a4312
  usecase "Purchase Skill" as UC_BuySkill #7a4312
  usecase "Upgrade Skill" as UC_UpgradeSkill #7a4312
}
rectangle "Persistence" #3f1d2e {
  usecase "player_inventory_items" as DB_PII #5b233f
  usecase "reward_transactions" as DB_RT #5b233f
  usecase "players" as DB_P #5b233f
  usecase "configs" as DB_C #5b233f
}
player --> UC_GetInv
player --> UC_UpgradeHero
player --> UC_EvolveHero
player --> UC_BuySkill
player --> UC_UpgradeSkill
UC_GetInv --> DB_PII
UC_UpgradeHero --> DB_PII
UC_EvolveHero --> DB_PII
UC_BuySkill --> DB_PII
UC_UpgradeSkill --> DB_PII
UC_UpgradeHero --> DB_RT
UC_EvolveHero --> DB_RT
UC_BuySkill --> DB_RT
UC_UpgradeSkill --> DB_RT
UC_UpgradeHero --> DB_P
UC_EvolveHero --> DB_P
UC_BuySkill --> DB_C
UC_UpgradeSkill --> DB_C
@enduml
