//////////////////////////////////////////////////////////////
// Synced with backend schema at prisma/schema.prisma
//////////////////////////////////////////////////////////////

Table USER [headercolor: #D6EAF8] {
  id string [pk]
  username string [unique]
  passwordHash string
  playerId string
  status string
  role string
  maxSession int
  max_game_user int
  createdAt datetime
  updatedAt datetime
  lastLoginAt datetime
}

Table SESSION [headercolor: #D6EAF8] {
  id string [pk]
  accountId string [ref: > USER.id]
  playerId string
  tokenHash string [unique]
  expiresAt datetime
  revokedAt datetime
  createdAt datetime
  userAgent string
  ip string

  indexes {
    (accountId)
    (playerId)
    (expiresAt)
  }
}

Table PLAYER [headercolor: #D5F5E3] {
  id string [pk]
  accountId string [unique, ref: > USER.id]
  profile json
  statistics json
  tutorialProgress json
  currency json
  configVersion string
  createdAt datetime
  updatedAt datetime
}

Table PLAYER_INVENTORY_ITEM [headercolor: #FCF3CF] {
  id string [pk]
  playerId string [ref: > PLAYER.id]
  itemId string
  itemType string
  itemClass string
  remainingUses int
  customData json
  createdAt datetime
  updatedAt datetime

  indexes {
    (playerId, itemType)
    (playerId, itemId)
  }
}

Table PLAYER_FORMATION [headercolor: #FCF3CF] {
  id string [pk]
  playerId string [ref: > PLAYER.id]
  name string
  slots json
  createdAt datetime
  updatedAt datetime

  indexes {
    (playerId, name) [unique]
  }
}

Table PLAYER_QUEST [headercolor: #FCF3CF] {
  id string [pk]
  playerId string [ref: > PLAYER.id]
  questId int
  type string
  actionId string
  progress int
  required int
  claimed boolean
  periodKey string
  createdAt datetime
  updatedAt datetime

  indexes {
    (playerId, questId, periodKey) [unique]
    (playerId, type, periodKey)
  }
}

Table PLAYER_QUEST_PROGRESS_REWARD [headercolor: #FCF3CF] {
  id string [pk]
  playerId string [ref: > PLAYER.id]
  track string
  stage int
  points int
  periodKey string
  reward json
  claimed boolean
  createdAt datetime
  updatedAt datetime

  indexes {
    (playerId, track, stage, periodKey) [unique]
    (playerId, track, periodKey)
  }
}

Table BATTLE_SESSION [headercolor: #FADBD8] {
  id string [pk]
  playerId string [ref: > PLAYER.id]
  opponentPlayerId string
  mode string
  seed int
  status string
  startedAt datetime
  expiresAt datetime
  finishedAt datetime
  result string
  summary json
  rewards json
  configVersion string

  indexes {
    (playerId, startedAt)
    (status, expiresAt)
    (opponentPlayerId)
  }
}

Table REWARD_TRANSACTION [headercolor: #FADBD8] {
  id string [pk]
  playerId string [ref: > PLAYER.id]
  sourceType string
  sourceId string
  idempotencyKey string
  changes json
  balanceAfter json
  createdAt datetime

  indexes {
    (playerId, createdAt)
    (sourceType, sourceId)
  }
}

Table LEADERBOARD_SCORE [headercolor: #FADBD8] {
  id string [pk]
  playerId string [ref: > PLAYER.id]
  type string
  score int
  displayName string
  avatar string
  country string
  updatedAt datetime

  indexes {
    (playerId, type) [unique]
    (type, score)
  }
}

Table IDEMPOTENCY_RECORD [headercolor: #FADBD8] {
  id string [pk]
  playerId string [ref: > PLAYER.id]
  idempotencyKey string
  action string
  requestHash string
  response json
  createdAt datetime

  indexes {
    (playerId, idempotencyKey) [unique]
    (playerId, createdAt)
  }
}

Table CONFIG [headercolor: #EAECEE] {
  id string [pk]
  name string
  version string
  isActive boolean
  records json
  createdAt datetime
  activatedAt datetime

  indexes {
    (name, version) [unique]
    (name, isActive)
  }
}

Table CHARACTER [headercolor: #D5F5E3] {
  id string [pk]
  character_name string
  race string
  gender string
  userId string [ref: > USER.id]
  isDeleted boolean
  isLocked boolean
}

Table CHARACTER_APPEARANCE [headercolor: #D5F5E3] {
  id string [pk]
  characterId string [unique, ref: > CHARACTER.id]
  hair string
  beard string
  eye string
  hairColor string
  beardColor string
  eyeColor string
}

Table CHARACTER_STATS [headercolor: #D5F5E3] {
  id string [pk]
  characterId string [unique, ref: > CHARACTER.id]
  str int
  dex int
  con int
  int int
  wis int
  cha int
  unspentPoints int
  hp int
  mp int
  patk int
  datk int
  matk int
  mdef int
  spd int
  crit int
  acc int
  eva int
  formulaVersion int
  updatedAt datetime
}

Table BACKUP [headercolor: #EAECEE] {
  id string [pk]
  backUpType string
  filePath string
  createAt datetime
  isDeleted boolean
  isLocked boolean

  indexes {
    (backUpType, createAt)
  }
}
