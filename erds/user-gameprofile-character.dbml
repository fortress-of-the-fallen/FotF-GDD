//////////////////////////////////////////////////////////////
// Scope (MVP Phase 1): Login + Create Profile + Create Character
// Keep only core fields. Stats/skills/combat data will be added in Phase 2.
//////////////////////////////////////////////////////////////

Table USER [headercolor: #D6EAF8] {
  _id ObjectId [pk]
  username string [not null, unique]
  email string [not null, unique]
  password_hash string
  role string
  status enum
  created_at datetime
  last_login date
}

Table GAME_PROFILE [headercolor: #D6EAF8] {
  _id ObjectId [pk]
  user_id ObjectId [not null, ref: > USER._id]
  profile_name string [not null]
  server_id string [note: 'Optional: Asia, NA...']
  created_at datetime
  last_played date

  indexes {
    (user_id)
    (user_id, profile_name) [unique]
  }
}

Table CHARACTER [headercolor: #D5F5E3] {
  _id ObjectId [pk]
  profile_id ObjectId [not null, ref: > GAME_PROFILE._id]
  name string [not null, note: 'User input at character creation']
  gender enum [not null, note: 'User selected at character creation']
  race enum [not null, note: 'User selected at character creation']
  appearance object [note: 'Random by server at character creation']
  creation_meta object [note: 'appearance_randomized=true, roll_seed, reroll_count']
  created_at datetime

  indexes {
    (profile_id) [unique]
  }
}
